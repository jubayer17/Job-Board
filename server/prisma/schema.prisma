// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model Account {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  userId             String  @db.Uuid @map("user_uuid")
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  sessionToken String   @unique
  userId       String   @db.Uuid @map("user_uuid")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  name          String?
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  applications  Application[]
  savedJobs     SavedJob[]
  isHR          Boolean       @default(false)
}

model VerificationToken {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Job {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  title        String
  company      String        @default("")
  location     String
  vacancy      String        @default("1")
  type         String
  applyLink    String        @default("")
  description  String        @db.Text
  status       String        @default("active") // active, closed, draft
  salary       String?
  logo         String?       // Company logo (text/emoji or url)
  logoPublicId String?
  logoOriginalName String?
  logoUploadedAt DateTime?
  tags         String[]      @default([]) // Array of tags/keywords
  salaryMin    Int?          // For filtering/sorting
  salaryMax    Int?          // For filtering/sorting
  postedAt     DateTime      @default(now())
  deadline     DateTime?
  vacancies    Int?          @default(1)
  experience   String?       // e.g. "1 to 3 years"
  education    String?       // e.g. "Bachelor of Science (BSc) in CSE"
  workplace    String?       // e.g. "Work at office", "Remote", "Hybrid"
  jobContext   String?       @db.Text
  gender       String?       @default("Both") // Male, Female, Both
  
  // New fields for comprehensive job details
  benefits         String[]  @default([])
  responsibilities String?   @db.Text
  skills           String[]  @default([])
  level            String?   // Entry, Mid, Senior, Executive

  roleCategory         String?
  workModel            String?
  companyCulture       String?  @db.Text
  careerGrowth         String?  @db.Text
  interviewProcess     String?  @db.Text
  industrySpecificRequirements String? @db.Text
  compensationCurrency String?
  payPeriod            String?
  bonusDetails         String?  @db.Text
  equityDetails        String?  @db.Text
  skillsAdvanced       String[] @default([])
  skillsIntermediate   String[] @default([])
  skillsFoundational   String[] @default([])
  softSkills           String[] @default([])
  certifications       String[] @default([])
  experienceMinYears   Int?
  experienceMaxYears   Int?
  travelRequirement    String?

  employer     Employer     @relation(fields: [employerId], references: [id])
  employerId   String       @db.Uuid @map("employer_uuid")

  applications Application[]
  savedBy      SavedJob[]

  companyId    String       @db.Uuid @map("company_uuid")
  companyRelation Company   @relation(fields: [companyId], references: [id])

  locationId   String?      @db.Uuid @map("location_uuid")
  locationRelation Location? @relation(fields: [locationId], references: [id])

  @@index([employerId])
  @@index([companyId])
  @@index([locationId])
  @@index([postedAt])
  @@index([salaryMax])
}

model Location {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  name      String   // Display name e.g. "Gulshan, Dhaka"
  city      String?
  state     String?
  country   String   @default("Bangladesh")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Application {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  jobId     String   @db.Uuid @map("job_uuid")
  userId    String   @db.Uuid @map("user_uuid")
  status    String   @default("PENDING")
  appliedAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, userId])
  @@index([jobId])
  @@index([userId])
  @@index([appliedAt])
}

model Employer {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  
  // Contact Person Info (Reusable)
  contactName        String
  contactDesignation String
  contactEmail       String    @unique
  contactMobile      String
  password           String

  companies          Company[]
  jobs               Job[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Company {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  companyName              String
  
  // Company Details
  tradeLicense             String?
  yearOfEstablishment      String?
  industryType             String?
  description              String?  @db.Text
  address                  String?
  websiteUrl               String?
  
  employerId               String   @db.Uuid @map("employer_uuid")
  employer                 Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)

  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  jobs                     Job[]

  @@index([employerId])
}

model SearchAnalytics {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  query     String
  results   Int
  clicked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Test {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
}

model SavedJob {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid @map("uuid_key")
  userId    String   @db.Uuid @map("user_uuid")
  jobId     String   @db.Uuid @map("job_uuid")
  savedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([jobId])
  @@index([userId])
  @@index([savedAt])
}
